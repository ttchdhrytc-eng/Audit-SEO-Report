# =========================================================================
# REVENUE CLUTCH SEO AUDIT ENGINE - ENVIRONMENT CONFIGURATION TEMPLATE
# =========================================================================
# Copy this template to .env and configure the variables below.
# DO NOT commit actual API keys or secrets to the source repository.

# ----------------- BACKEND / NODE API SECRET KEYS -----------------

# ALLOWED_ORIGINS: Comma-separated list of whitelisted cross-origin domains.
# Requests with cross-origin headers not on this list will be rejected with HTTP 403.
# Example: https://audit-seo-report.domain.workers.dev,http://localhost:3000
ALLOWED_ORIGINS=""

# ADMIN_PASSWORD: The master administrator password used to authorize access to protected views.
ADMIN_PASSWORD=""

# USER_PASSWORD: The regular user password used to authorize access to general user-level features.
USER_PASSWORD=""

# JWT_SECRET: The secret key token used to sign and verify administrative JWTs.
JWT_SECRET=""

# GEMINI_API_KEY: Required for Gemini AI core audits, copy briefs, and recommendations.
# In Google AI Studio, this is automatically injected securely from your configured user secrets.
GEMINI_API_KEY=""

# PAGESPEED_API_KEY: Google PageSpeed Insights API key for performance & Lighthouse score retrieval.
PAGESPEED_API_KEY=""

# OPENGRAPH_API_KEY: Opengraph.io proxy scraping API app-id for crawling external sites securely.
OPENGRAPH_API_KEY=""

# ----------------- GOOGLE SEARCH CONSOLE OAUTH CONFIG (BACKEND / WORKERS) -----------------

# GSC_CLIENT_ID: Google OAuth 2.0 Web Application Client ID for Search Console integration.
GSC_CLIENT_ID=""

# GSC_CLIENT_SECRET: Google OAuth 2.0 Web Application Client Secret for token exchange.
GSC_CLIENT_SECRET=""

# GSC_REDIRECT_URI: The exact redirect URI registered under Google Developer Console.
# Example: https://revenue-clutch-api.domain.workers.dev/api/oauth/callback
GSC_REDIRECT_URI=""

# FRONTEND_CLIENT_URL: The front-end domain where your SPA dashboard is currently hosted.
# Example: https://audit-seo-report.domain.workers.dev
FRONTEND_CLIENT_URL=""

# ----------------- CLIENT-SIDE ENVIRONMENT VARIABLES (VITE) -----------------

# VITE_GSC_CLIENT_ID: Google OAuth 2.0 Web Client ID used by the SPA frontend in implicit oauth flow.
# Note: Must be prefixed with VITE_ to be exposed to client-side code by Vite.
VITE_GSC_CLIENT_ID=""
